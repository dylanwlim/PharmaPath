{
  "name": "pharmapath",
  "version": "0.1.0",
  "private": true,
  "description": "Medication-access search app for pharmacy discovery, medication context, and transparent availability guidance.",
  "homepage": "https://www.pharmapath.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/dylanwlim/PharmaPath.git"
  },
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "setup:local": "bash scripts/codex/setup-local.sh",
    "build": "npm run medications:build-assets && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npm run medications:build-assets && node --test tests/*.test.js",
    "test:pharmacy": "npm run medications:build-assets && node --test tests/google-api-config.test.js tests/pharmacy-burst-hardening.test.js tests/pharmacy-fallback.test.js tests/pharmacy-location.test.js tests/pharmacy-search-phone.test.js",
    "test:openfda": "npm run medications:build-assets && node --test tests/openfda-burst-hardening.test.js tests/openfda-normalize.test.js tests/openfda-shortages.test.js",
    "test:medications": "npm run medications:build-assets && node --test tests/medication-index.test.js",
    "test:burst": "node scripts/burst-traffic-smoke.mjs",
    "clean:codex": "bash scripts/codex/cleanup.sh",
    "validate": "npm run lint && npm run typecheck && npm test && npm run build",
    "medications:build-assets": "node scripts/medications/build-runtime-assets.mjs",
    "medications:sync": "node scripts/medications/sync-openfda-index.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "framer-motion": "^12.4.10",
    "lucide-react": "^0.542.0",
    "next": "^16.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.4",
    "stream-chain": "^3.4.0",
    "stream-json": "^1.9.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "^1.3.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "globals": "^17.4.0",
    "postcss": "8.5.6",
    "typescript": "~5.7.2"
  }
}
